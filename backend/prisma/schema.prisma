generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  BOOKKEEPER
  API_USER
}

// SimpleBooks user — bootstraps from env (ADMIN_USERNAME + ADMIN_PASSWORD)
// on first boot and every subsequent boot reconciles that row. Non-env users
// are created by admin via /settings/users. passwordHash is NULL for the
// env-admin (validated against env vars at login) and for API_USER rows
// (which authenticate via ApiKey rather than password).
model User {
  id                   String    @id @default(uuid())
  username             String    @unique
  displayName          String
  email                String?   @unique
  role                 UserRole
  passwordHash         String?
  isActive             Boolean   @default(true)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  sessions           Session[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  tasks              Task[]
  telegramChats      TelegramChat[]
  telegramAllowlists TelegramAllowlist[]
}

// Active login session — one row per cookie. `token` is a high-entropy
// random string stored verbatim (it never leaves the server except as the
// httpOnly cookie value, and is only compared via timingSafeEqual).
// Expired rows are purged daily by AuthService.
model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// API key — issued by admin to an API_USER row. `keyHash` is the argon2id
// digest of the secret; `prefix` is the visible "sb_live_xxxxxxxx"
// (first 8 chars after the brand prefix) shown in the list UI so admins
// can identify a key after its full value is gone. Last 4 chars of the
// secret also stored as `suffix` to aid scanning leaked-key reports.
model ApiKey {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  keyHash     String    @unique
  prefix      String
  suffix      String
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// Per-role per-capability override. When present, the row overrides the
// hard-coded default. Absent rows fall through to the default capability
// matrix for the role. The Settings/Roles UI writes here.
model RoleOverride {
  id         String   @id @default(uuid())
  role       UserRole
  capability String
  allowed    Boolean
  updatedAt  DateTime @updatedAt

  @@unique([role, capability])
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  LOGOUT
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  ROLE_CHANGED
  ROLE_OVERRIDE_CHANGED
  API_KEY_CREATED
  API_KEY_REVOKED
  RESOURCE_DELETED
  DATA_RETENTION_PURGE
}

// Append-only audit trail. Recorded by the AuditInterceptor for every
// DELETE-method route + explicitly by services for the action enum above.
// `actor` is the authenticated user (null only for the failed-login case
// where we couldn't match a username). Purged on demand from /settings/
// data-retention.
model AuditLog {
  id         String      @id @default(uuid())
  action     AuditAction
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  targetType String?
  targetId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([action])
  @@index([actorId])
  @@index([createdAt])
}

enum PaymentTerms {
  IN_28_DAYS
  IN_15_DAYS
  IN_7_DAYS
  DUE_ON_RECEIPT
}

model Customer {
  id               String        @id @default(uuid())
  customerNumber   Int           @unique
  name             String
  billingEmail1    String?
  billingEmail2    String?
  billingCompanyId String?
  paymentTerms     PaymentTerms  @default(IN_28_DAYS)
  address          String?
  notes            String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  // Soft-delete. Set to the time of DELETE; a daily sweep hard-deletes after
  // 30 days. NULL = live row. List/get queries filter out non-null.
  deletedAt        DateTime?
  @@index([deletedAt])

  billingCompany BillingCompany? @relation(fields: [billingCompanyId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  recurringRules RecurringRule[]
  tags           Tag[]
  categories     Category[]
  linkedTransactions Transaction[] @relation("LinkedTransactions")
}

enum SendVia {
  GENERAL_SMTP
  CUSTOM_SMTP
}

model BillingCompany {
  id             String    @id @default(uuid())
  name           String
  abn            String?
  address        String?
  paymentDetails String?
  accountsEmail  String?
  invoiceBcc     String    @default("")
  notes          String?
  isActive       Boolean   @default(true)
  deactivatedAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Outbound mail routing for invoices issued by this company.
  // GENERAL_SMTP (default): use the system's MailConfiguration.
  // CUSTOM_SMTP: use this company's own credentials below.
  sendVia              SendVia          @default(GENERAL_SMTP)
  customSmtpServer     String?
  customSmtpPort       Int?
  customSmtpEncryption EmailEncryption?
  customSmtpUser       String?
  customSmtpPassword   String?

  // Permanent rotation-based template assignment. `creationOrder` is the 1-based
  // ordinal of this company within the BillingCompany table; the assigned
  // template displayOrders are `((creationOrder - 1) % templateCount) + 1`.
  // Computed once at create-time and never changed thereafter; FKs are
  // `Restrict` so a referenced template can't be deleted while still in use.
  creationOrder      Int?    @unique
  invoiceTemplateId  String?
  emailTemplateId    String?
  invoiceTemplate    InvoiceTemplate? @relation(fields: [invoiceTemplateId], references: [id], onDelete: Restrict)
  emailTemplate      EmailTemplate?   @relation(fields: [emailTemplateId], references: [id], onDelete: Restrict)

  customers       Customer[]
  invoices        Invoice[]
  recurringRules  RecurringRule[]
}

model Item {
  id          String   @id @default(uuid())
  name        String
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceItems        InvoiceItem[]
  recurringLineItems  RecurringRuleLineItem[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIAL_PAID
  PAID
  VOID
  FAILED_TO_SEND
}

model Invoice {
  id               String        @id @default(uuid())
  invoiceNumber    Int           @unique
  invoiceDate      DateTime      @default(now())
  dueDate          DateTime?
  customerId       String?
  billingCompanyId String?
  status           InvoiceStatus @default(DRAFT)
  subtotal         Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount        Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount      Decimal       @db.Decimal(12, 2) @default(0)
  poNumber         String?
  paymentDetails   String?
  internalNotes    String?
  terms            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  // Soft-delete. Set to the time of DELETE; a daily sweep hard-deletes after
  // 30 days. NULL = live row. List/get queries filter out non-null.
  deletedAt        DateTime?
  @@index([deletedAt])

  customer        Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  billingCompany  BillingCompany? @relation(fields: [billingCompanyId], references: [id], onDelete: SetNull)
  lineItems       InvoiceItem[]
  recurringRuleId String?
  recurringRule   RecurringRule?  @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)

  // Template snapshots, copied from the parent BillingCompany at invoice
  // creation. Frozen for the lifetime of the invoice so historical renders are
  // reproducible even if the company's live assignment ever changed.
  invoiceTemplateId String?
  emailTemplateId   String?
  invoiceTemplate   InvoiceTemplate? @relation(fields: [invoiceTemplateId], references: [id], onDelete: Restrict)
  emailTemplate     EmailTemplate?   @relation(fields: [emailTemplateId], references: [id], onDelete: Restrict)

  // Send-attempt tracking. Populated by the manual-send flow and by the
  // recurring processor's SEND_DIRECTLY path. `sendAttempts` counts the total
  // number of SMTP attempts made for this invoice (the first synchronous
  // attempt + up to 3 BullMQ-retried attempts = 4 max). `sendError` holds the
  // most recent SMTP error verbatim so the UI can show why it failed.
  sendAttempts Int       @default(0)
  sendError    String?
  lastSendAt   DateTime?

  // Public-link surface. `publicToken` is a 32-byte URL-safe random string
  // minted lazily the first time the invoice is sent; it backs the customer-
  // facing /i/:token page. `viewedAt` stamps the first GET on that page, and
  // the SENT → VIEWED status transition fires alongside it (idempotent).
  publicToken         String?   @unique
  publicTokenIssuedAt DateTime?
  viewedAt            DateTime?

  // Void audit. `voidReason` is captured from the operator at void time
  // (free-text). `voidedAt` is stamped on the same transaction that flips
  // status to VOID. Both stay readable on the invoice forever so the audit
  // trail survives even though the dashboard excludes VOIDs from aggregates.
  voidReason String?
  voidedAt   DateTime?

  amountPaid        Decimal      @db.Decimal(12, 2) @default(0)
  amountOutstanding Decimal      @db.Decimal(12, 2) @default(0)

  allocations Allocation[]
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  itemId      String?
  description String
  quantity    Decimal @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineAmount  Decimal @db.Decimal(12, 2)
  taxTypeId   String?
  taxName     String?
  taxRate     Decimal? @db.Decimal(6, 3)
  taxAmount   Decimal @db.Decimal(12, 2) @default(0)
  position    Int      @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item?   @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  dueDate     DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum RecurringIntervalUnit {
  DAYS
  WEEKS
  MONTHS
  YEARS
}

enum SendingOption {
  REVIEW_BEFORE_SENDING
  SEND_DIRECTLY
}

model RecurringSchedule {
  id            String                @id @default(uuid())
  name          String                @unique
  intervalUnit  RecurringIntervalUnit
  intervalCount Int
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  recurringRules RecurringRule[]
}

model RecurringRule {
  id                  String         @id @default(uuid())
  scheduleName        String
  startDate           DateTime
  recurringScheduleId String?
  sendingOption       SendingOption  @default(REVIEW_BEFORE_SENDING)
  active              Boolean        @default(true)
  nextRunAt           DateTime
  customerId          String?
  billingCompanyId   String?
  poNumber            String?
  paymentDetails      String?
  internalNotes       String?
  terms               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  recurringSchedule RecurringSchedule? @relation(fields: [recurringScheduleId], references: [id], onDelete: SetNull)
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  billingCompany    BillingCompany?    @relation(fields: [billingCompanyId], references: [id], onDelete: SetNull)
  lineItems         RecurringRuleLineItem[]
  invoices          Invoice[]
}

model RecurringRuleLineItem {
  id              String   @id @default(uuid())
  recurringRuleId String
  itemId          String?
  description     String
  unitPrice       Decimal  @db.Decimal(12, 2)
  taxTypeId       String?
  taxName         String?
  taxRate         Decimal? @db.Decimal(6, 3)
  position        Int      @default(0)

  recurringRule RecurringRule @relation(fields: [recurringRuleId], references: [id], onDelete: Cascade)
  item          Item?         @relation(fields: [itemId], references: [id], onDelete: SetNull)
}

model TelegramChat {
  id        String   @id @default(cuid())
  chatId    String   @unique
  username  String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum EmailEncryption {
  NONE
  SSL
  TLS
  STARTTLS
}

model TaxType {
  id          String   @id @default(uuid())
  name        String
  rate        Decimal  @db.Decimal(6, 3)
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvoiceTemplate {
  id           String   @id @default(uuid())
  name         String
  templateKey  String   @unique
  // 1..10 — the rotation slot a BillingCompany maps onto. Each templateKey
  // also maps to a React-PDF .tsx module under `src/pdf/templates/`; until the
  // user provides all 10 real designs, every key renders via the default
  // template (see `src/pdf/templates/index.ts`).
  displayOrder Int      @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  billingCompanies BillingCompany[]
  invoices         Invoice[]
}

model EmailTemplate {
  id           String   @id @default(uuid())
  name         String
  // Subject + body are stored verbatim and may contain dynamic-fields tokens
  // (e.g. `{{billing company}}`). Substituted at send time by MailService
  // against the host invoice's context. Body is HTML; there is no plain-text
  // alternative — every customer-facing email is HTML.
  subject      String
  body         String   @default("")
  templateKey  String   @unique
  displayOrder Int      @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  billingCompanies BillingCompany[]
  invoices         Invoice[]
}

model Preferences {
  id                  String   @id @default(uuid())
  timezone            String   @default("Australia/Perth")
  financialYearStart  Int      @default(7)
  aiMiningThreshold   Int      @default(3)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MailConfiguration {
  id         String          @id @default(uuid())
  smtpServer String          @default("")
  port       Int             @default(587)
  encryption EmailEncryption @default(STARTTLS)
  user       String          @default("")
  password   String          @default("")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

// Allowlisted Telegram handle. `userId` is the FK to the SimpleBooks user
// the bot acts as for this handle — every bot command runs through the
// linked user's role and capabilities. Nullable for backwards-compat with
// rows seeded before the link existed; bot rejects commands from rows with
// a null userId.
model TelegramAllowlist {
  id        String   @id @default(uuid())
  username  String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  botName   String?
  botToken  String?
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Banking ─────────────────────────────────────────────────────────────────

// Lookup of account types. Seeded with the six common AU personal types; the
// user can add/rename/deactivate from /settings/account-types. FK Restrict on
// Account.accountTypeId means a type can't be deleted while in use (mirrors
// BillingCompany → InvoiceTemplate).
model AccountType {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  accounts Account[]
}

// A bank account the user tracks. `openingBalance` + `openingDate` anchor the
// running-balance computation; current balance = openingBalance + SUM(amount)
// across all transactions. Soft-delete only (isActive).
model Account {
  id             String      @id @default(uuid())
  name           String      @unique
  bank           String
  accountNumber  String?
  accountTypeId  String
  accountType    AccountType @relation(fields: [accountTypeId], references: [id], onDelete: Restrict)
  openingBalance Decimal     @db.Decimal(14, 2) @default(0)
  openingDate    DateTime    @db.Date
  notes          String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions Transaction[]
  imports      TransactionImport[]
}

// A single bank-statement line. `amount` is SIGNED (negative=debit,
// positive=credit). Balance is derived (Account.openingBalance + Σ amount)
// at query time via a window function — not stored. `importHash` is the
// dedupe key — sha256 of date|amount.toFixed(2)|normaliseDesc(description),
// uniqued per account.
model Transaction {
  id              String   @id @default(uuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  date            DateTime @db.Date
  amount          Decimal  @db.Decimal(14, 2)
  description     String

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Per-transaction customer link populated by the deterministic linker
  // (POST /transactions/link-customers). When set, takes precedence over
  // category.customerId / tag.customerId in the payments candidate query.
  linkedCustomerId String?
  linkedCustomer   Customer? @relation("LinkedTransactions", fields: [linkedCustomerId], references: [id], onDelete: SetNull)
  linkedCustomerSource String?  // "INVOICE_NUMBER" | "EXACT_AMOUNT" | "NAME_TOKEN" | "MANUAL"

  notes String?

  ruleId String?
  rule   Rule?   @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  categorisedAt DateTime?

  importHash String
  importId   String?
  import     TransactionImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  splits          TransactionSplit[]
  events          CategorisationEvent[]
  transactionTags TransactionTag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentReviewDismissedAt DateTime?
  allocations              Allocation[]

  @@unique([accountId, importHash])
  @@index([accountId, date])
  @@index([date])
}

// One row per CSV import attempt — always created, even on zero-import or
// all-failed outcomes, so the audit trail is complete. `reportJson` holds
// the full ImportReport shape consumed by <ImportReportPopup>.
model TransactionImport {
  id         String   @id @default(uuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  filename   String
  fileSize   Int
  fileSha256 String
  importedAt DateTime @default(now())

  mappingJson    Json
  rowsTotal      Int
  rowsImported   Int
  rowsSkippedDup Int
  rowsFailed     Int
  reportJson     Json

  transactions Transaction[]
}

// ── Banking Phase B ──────────────────────────────────────────────────

enum CategoryKind {
  INCOME
  EXPENSE
  TRANSFER
  OTHER
}

enum RuleState {
  USER
  AI_DRAFTED
  APPROVED
  DENIED
}

enum RuleField {
  DESCRIPTION
  AMOUNT
  ACCOUNT
}

enum RuleOperator {
  CONTAINS
  EQUALS
  STARTS_WITH
  ENDS_WITH
  GT
  LT
  BETWEEN
  IN
}

enum EventSource {
  USER
  RULE
  AI_DRAFT
  AI_APPLIED
  AI_REJECTED
  AUTO_ALIAS
}

model Category {
  id        String       @id @default(uuid())
  name      String       // was @unique — replaced by service-layer sibling-scoped check
  kind      CategoryKind
  isActive  Boolean      @default(true)
  sortOrder Int          @default(100)
  parentId  String?      // self-referential FK; null for top-level
  parent    Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children  Category[]   @relation("CategoryHierarchy")
  customerId String?     // optional link to a Customer — used by Payments scorer to boost invoices for this customer
  customer  Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  transactions      Transaction[]
  transactionSplits TransactionSplit[]
  rules             Rule[]

  @@index([parentId])
  @@index([customerId])
}

model Tag {
  id         String   @id @default(uuid())
  name       String   // case-insensitive unique enforced in service layer
  aliases    String[] // extra description-substring patterns that match this tag
  color      String?  // optional UI badge color (hex without # or tailwind token)
  notes      String?
  // Free-text classifier for the tag (e.g. "Vehicle", "Property",
  // "Subcontractor", "Customer", "Family"). Surfaced in /tags filtering so
  // users can scope to one facet of their tag list. Not enforced as an enum
  // so users can introduce new kinds without a schema change.
  kind       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  transactionTags TransactionTag[]

  @@index([customerId])
}

model TransactionTag {
  transactionId String
  tagId         String
  source        EventSource @default(USER) // USER | RULE | AI_APPLIED | AUTO_ALIAS
  createdAt     DateTime    @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@index([tagId])
}

model Rule {
  id          String     @id @default(uuid())
  name        String
  state       RuleState  @default(USER)
  isActive    Boolean    @default(true)
  priority    Int        @default(1000)

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  noteOnApply String?
  clusterHash String?

  hitCount    Int        @default(0)
  lastFiredAt DateTime?

  conditions   RuleCondition[]
  events       CategorisationEvent[]
  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([priority])
  @@index([state, isActive])
  @@index([clusterHash])
}

model RuleCondition {
  id        String       @id @default(uuid())
  ruleId    String
  rule      Rule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  field     RuleField
  operator  RuleOperator
  value     String
  value2    String?
  valueList String[]
  position  Int          @default(0)

  @@index([ruleId])
}

model TransactionSplit {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  amount        Decimal     @db.Decimal(14, 2)
  notes         String?
  position      Int         @default(0)

  @@index([transactionId])
}

// Configuration for an OpenAI-compatible AI provider. Phase C reads these
// to make AI calls; Phase B only persists the records. At most one provider
// has isPrimary=true (server-enforced in set-primary).
model AiProvider {
  id         String   @id @default(uuid())
  name       String
  model      String
  apiBaseUrl String
  apiKey     String                          // stored plain (matches existing customSmtpPassword pattern)
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(1000)
  requestsPerMinute Int @default(15)   // per-provider self-pacing ceiling. Tier hints: ~15 free, ~60 paid lite, ~1000 paid.
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  calls      AiCall[]
  events     CategorisationEvent[]
  @@index([isPrimary, sortOrder])
}

model CategorisationEvent {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  source        EventSource
  ruleId        String?
  rule          Rule?       @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  oldCategoryId String?
  newCategoryId String?

  acceptedAiSuggestion Boolean?
  reasoning String?

  providerId String?
  provider   AiProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@index([source, createdAt])
  @@index([ruleId])
  @@index([providerId])
}

enum AiCallPurpose {
  CATEGORISE
  DRAFT_RULE
}

enum AiCallStatus {
  OK
  FAILED
}

model AiCall {
  id               String        @id @default(uuid())
  providerId       String
  provider         AiProvider    @relation(fields: [providerId], references: [id], onDelete: Cascade)
  purpose          AiCallPurpose
  promptTokens     Int?
  completionTokens Int?
  latencyMs        Int
  status           AiCallStatus
  httpStatus       Int?
  errorMessage     String?
  transactionId    String?
  ruleId           String?
  createdAt        DateTime      @default(now())

  @@index([providerId, createdAt])
  @@index([status, createdAt])
  @@index([transactionId])
  @@index([ruleId])
}

enum AllocationEventType {
  CREATED
  DELETED
}

enum AllocationEventSource {
  USER
}

model Allocation {
  id            String      @id @default(uuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoiceId     String
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  amount        Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())

  @@index([transactionId])
  @@index([invoiceId])
}

model AllocationEvent {
  id                  String                @id @default(uuid())
  eventType           AllocationEventType
  transactionId       String
  invoiceId           String
  amount              Decimal               @db.Decimal(14, 2)
  invoiceStatusBefore InvoiceStatus
  invoiceStatusAfter  InvoiceStatus
  source              AllocationEventSource @default(USER)
  createdAt           DateTime              @default(now())

  @@index([transactionId])
  @@index([invoiceId])
  @@index([createdAt])
}

// Per-table auto-purge schedule for log/audit tables. Drives a daily BullMQ
// sweep that calls RetentionService.purge() for each enabled row. The `table`
// PK is the same string used in the Data Retention UI ("AuditLog", "AiCall",
// etc). Manual purge from the UI is unaffected — this just adds a scheduled
// path. `cutoffAge` is one of: '7d' | '30d' | '90d' | '1y'.
model RetentionPolicy {
  table     String   @id
  cutoffAge String
  enabled   Boolean  @default(false)
  lastRunAt DateTime?
  updatedAt DateTime @updatedAt
}
