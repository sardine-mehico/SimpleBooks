# =============================================================================
# SimpleBooks — VPS production env example
# Copy to `.env` on the VPS and fill the marked values.
# =============================================================================

# ---- Release tag (matches docker images on GHCR) ---------------------------
TAG=0.2
IMAGE_OWNER=sardine-mehico    # change if you forked the repo

# ---- Database (internal) ---------------------------------------------------
# These can stay as-is; nothing else needs the literal values, they are wired
# into DATABASE_URL below.
POSTGRES_USER=simplebooks
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=simplebooks
DATABASE_URL=postgresql://simplebooks:change-me-to-a-long-random-string@postgres:5432/simplebooks?schema=public
REDIS_URL=redis://redis:6379

PORT=4000
NODE_ENV=production

# ---- Public URLs -----------------------------------------------------------
# Both URLs are read at runtime — change them, restart the stack, no rebuild
# needed. The frontend injects API_URL into the HTML at each request, so the
# same image works for any domain.
#   API_URL          → browser-facing backend URL (used by user browsers)
#   PUBLIC_APP_URL   → backend uses this to build /i/<token> links in emails
# Both REQUIRED. API_URL must include /api per the reverse-proxy routing.
API_URL=https://simplebooks.officepc.online/api
PUBLIC_APP_URL=https://simplebooks.officepc.online

# ---- SMTP (via Brevo / SendGrid / your provider) ---------------------------
# Not used by env — configured via /settings/mail-configuration in the UI.
# Left here as a reminder.

# ---- Telegram bot (optional; leave empty to disable) -----------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=simplebooks.officepc.online
TELEGRAM_WEBHOOK_SECRET=a-random-string-to-protect-the-webhook-endpoint

# ---- Resend (HTTPS notification channel — optional) ------------------------
RESEND_API_KEY=
RESEND_FROM=SimpleBooks <onboarding@resend.dev>

# ---- AI runtime (defaults shown — only override if needed) -----------------
AI_TIMEOUT_INLINE_MS=20000
AI_TIMEOUT_BULK_MS=60000
AI_BULK_CONCURRENCY=5
