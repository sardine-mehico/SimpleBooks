# =============================================================================
# SimpleBooks — environment template
# Copy this file to `.env` and fill in the values you need. Sections marked
# REQUIRED must be set or the backend will refuse to start. Everything else
# is optional and can be configured later from the UI.
# =============================================================================


# =============================================================================
# REQUIRED — Database
# =============================================================================
# Compose uses these literal values to bring up Postgres. The same values are
# wired into DATABASE_URL below so the backend can connect.
POSTGRES_USER=simplebooks
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=simplebooks

DATABASE_URL=postgresql://simplebooks:change-me-to-a-long-random-string@postgres:5432/simplebooks?schema=public
REDIS_URL=redis://redis:6379

PORT=4000

# Set to "development" only for local LAN dev WITHOUT TLS in front. In
# production this MUST be "production" so the session cookie is marked Secure.
NODE_ENV=production


# =============================================================================
# REQUIRED — Admin user
# =============================================================================
# Canonical admin login. The password remains valid for the lifetime of the
# deploy — there's no rotation through the UI. Edit here + restart to change.
# Pick something long and unique.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password


# =============================================================================
# REQUIRED — Public URLs
# =============================================================================
# Both URLs are read at runtime. Change them, restart the frontend container,
# no rebuild needed — the frontend injects API_URL into the HTML on each
# request, so the same image works for any domain.
#
#   API_URL          → browser-facing backend URL (what users' browsers hit)
#   PUBLIC_APP_URL   → backend uses this to build /i/<token> invoice links
#
# DEPLOYMENT CONVENTION
#   Frontend served at  https://<your-domain>            (Next.js,  internal :3000)
#   Backend  served at  https://<your-domain>/api        (NestJS,   internal :4000)
#   A reverse proxy (Nginx Proxy Manager / Caddy / Traefik) routes /api/*
#   to backend:4000 and everything else to frontend:3000.
#
# API_URL MUST include /api — the backend doesn't strip it; the proxy does.
# PUBLIC_APP_URL MUST NOT include /api — it's the frontend root.

# Local dev:   http://localhost:4000        Production: https://billing.mysite.com/api
API_URL=http://localhost:4000

# Local dev:   http://localhost:3000        Production: https://billing.mysite.com
PUBLIC_APP_URL=http://localhost:3000

# Legacy alias kept for backwards compatibility with old build args. New
# deploys should not need this — leave commented unless you know you do.
# NEXT_PUBLIC_API_URL=http://localhost:4000


# =============================================================================
# OPTIONAL — Telegram bot
# =============================================================================
# Leave TELEGRAM_BOT_TOKEN empty to disable the bot entirely. With a token
# set the bot starts in long-poll mode; setting TELEGRAM_WEBHOOK_DOMAIN
# switches it to webhook mode (recommended for production).
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_SECRET=

# Comma-separated Telegram usernames (no @). Each becomes a TelegramAllowlist
# row linked to the env admin on first boot. The bot acts as the linked
# SimpleBooks user. Recommendation: link your own handle to admin for full
# bot capability.
# Example: TELEGRAM_ALLOWLIST_USERNAMES=yourhandle,otherhandle
TELEGRAM_ALLOWLIST_USERNAMES=


# =============================================================================
# OPTIONAL — SMTP (customer-facing email)
# =============================================================================
# Used for sending invoices and statements to your customers. All five fields
# below are required together — partial config logs a warning and is skipped.
# After first boot, edits in /settings/mail-configuration always win.
# SMTP_ENCRYPTION must be one of: NONE | SSL | TLS | STARTTLS
SMTP_HOST=
SMTP_PORT=
SMTP_ENCRYPTION=
SMTP_USER=
SMTP_PASSWORD=


# =============================================================================
# OPTIONAL — Resend (failure-notification email)
# =============================================================================
# Separate HTTPS channel used by NotificationsService for "invoice send
# failed" alerts so a broken customer SMTP can't suppress its own alerts.
# Free tier 100/day at https://resend.com. Leave empty to skip — Telegram
# remains the primary channel. Override RESEND_FROM once you've verified a
# custom sending domain in Resend.
RESEND_API_KEY=
RESEND_FROM=SimpleBooks <onboarding@resend.dev>


# =============================================================================
# OPTIONAL — AI providers (two slots: primary + fallback)
# =============================================================================
# Each slot needs NAME + MODEL + API_BASE_URL + API_KEY to seed on first
# boot. RPM is requests-per-minute (default 15). After first boot, edits in
# /settings/ai-setup always win.
#
# Example (OpenAI):
#   AI_PROVIDER_1_NAME=OpenAI
#   AI_PROVIDER_1_MODEL=gpt-4o-mini
#   AI_PROVIDER_1_API_BASE_URL=https://api.openai.com/v1
#   AI_PROVIDER_1_API_KEY=sk-...
#
# Example (Gemini via OpenAI-compatible endpoint):
#   AI_PROVIDER_2_NAME=Gemini
#   AI_PROVIDER_2_MODEL=gemini-2.0-flash
#   AI_PROVIDER_2_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   AI_PROVIDER_2_API_KEY=...

AI_PROVIDER_1_NAME=
AI_PROVIDER_1_MODEL=
AI_PROVIDER_1_API_BASE_URL=
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_RPM=15

AI_PROVIDER_2_NAME=
AI_PROVIDER_2_MODEL=
AI_PROVIDER_2_API_BASE_URL=
AI_PROVIDER_2_API_KEY=
AI_PROVIDER_2_RPM=15

# AI runtime tuning (defaults shown — only change if you know why).
AI_TIMEOUT_INLINE_MS=20000
AI_TIMEOUT_BULK_MS=60000
AI_BULK_CONCURRENCY=5
