# PostgreSQL
POSTGRES_USER=accounting
POSTGRES_PASSWORD=accounting
POSTGRES_DB=accounting

# Backend
DATABASE_URL=postgresql://accounting:accounting@postgres:5432/accounting?schema=public
REDIS_URL=redis://redis:6379
PORT=4000
NODE_ENV=production

# Admin user — REQUIRED. Backend refuses to start without both set. This is
# the canonical admin login; the password remains valid for the lifetime of
# the deploy (no UI-driven rotation), edit here + restart to change. Pick
# something long and unique.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-please-set-a-strong-password

# ── Optional first-run env bootstrap ────────────────────────────────────────
# Each block is idempotent: written to the DB only when the corresponding
# row(s) are absent. UI edits made after first run always win — the env is
# never re-applied to overwrite changes.

# SMTP — all five required to seed MailConfiguration. Partial config is
# ignored with a warning.
SMTP_HOST=
SMTP_PORT=
SMTP_ENCRYPTION=        # NONE | SSL | TLS | STARTTLS
SMTP_USER=
SMTP_PASSWORD=

# Telegram allowlist — comma-separated usernames (no @). Each becomes a
# TelegramAllowlist row linked to the env admin. The bot acts as that user.
# RECOMMENDATION: link your own Telegram handle to admin for full bot capability.
TELEGRAM_ALLOWLIST_USERNAMES=

# AI providers — two optional slots. Slot 1 = primary, slot 2 = fallback.
# All four fields required per slot to seed.
AI_PROVIDER_1_NAME=
AI_PROVIDER_1_MODEL=
AI_PROVIDER_1_API_BASE_URL=
AI_PROVIDER_1_API_KEY=
AI_PROVIDER_1_RPM=15

AI_PROVIDER_2_NAME=
AI_PROVIDER_2_MODEL=
AI_PROVIDER_2_API_BASE_URL=
AI_PROVIDER_2_API_KEY=
AI_PROVIDER_2_RPM=15

# Telegram (leave empty to disable the bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_DOMAIN=
TELEGRAM_WEBHOOK_SECRET=

# Resend (HTTPS transactional email used for send-failure notifications —
# separate channel from customer-facing SMTP). Leave empty to skip the email
# notification path; Telegram remains the primary channel. Get a key at
# https://resend.com — free tier 100/day.
RESEND_API_KEY=
RESEND_FROM=SimpleBooks <onboarding@resend.dev>

# ---------------------------------------------------------------------------
# Public URLs (point at how YOUR USERS reach the app)
# ---------------------------------------------------------------------------
# DEPLOYMENT CONVENTION
#   Frontend served at  https://<your-domain>            (Next.js container, internal :3000)
#   Backend  served at  https://<your-domain>/api        (NestJS container, internal :4000)
#   A reverse proxy (Caddy / Nginx / Traefik) routes /api/* to backend:4000
#   and everything else to frontend:3000.
#
# The `/api` suffix on NEXT_PUBLIC_API_URL is REQUIRED if you follow this
# pattern — the backend doesn't strip /api itself; the reverse proxy does.
# Without it the frontend tries to hit https://<your-domain>/companies etc.
# directly and collides with frontend routes.
#
# NEXT_PUBLIC_* values are BAKED INTO THE JS BUNDLE at `next build` time.
# Set them BEFORE `docker compose build frontend` — exporting them at run time
# is too late. After any change, rebuild the frontend image and restart.

# Browser-side backend URL.
# Local dev:    http://localhost:4000
# Production:   https://billing.mysite.com/api    (note the /api suffix)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Customer-facing absolute URL where the public invoice page is reachable
# (`/i/<token>`). Used by the backend to build the link injected via
# `{{invoice link}}` / `{{invoice link button}}` into outgoing invoice
# emails AND on the View PDF / send dialog preview.
# Required for sending — MailService refuses to send without it.
# Local dev:    http://localhost:3000
# Production:   https://billing.mysite.com        (NO /api — this is the frontend root)
PUBLIC_APP_URL=http://localhost:3000

# SMTP Details used during development
SMTP Server=
Port=
Username=
Password=

# Phase C — AI runtime (all optional; defaults shown)
AI_TIMEOUT_INLINE_MS=20000
AI_TIMEOUT_BULK_MS=60000
AI_BULK_CONCURRENCY=5
