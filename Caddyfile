# Caddy config for SimpleBooks. Replace simplebooks.officepc.online with your
# real domain — Caddy will auto-provision Let's Encrypt certs on first boot.
#
# Routing:
#   /api/*   → backend container :4000  (Caddy strips /api/ before forwarding)
#   /*       → frontend container :3000

simplebooks.officepc.online {
    encode gzip
    handle_path /api/* {
        reverse_proxy backend:4000
    }
    handle {
        reverse_proxy frontend:3000
    }
}

# Local-dev fallback so `caddy run` against localhost still works.
# Remove if you don't need it.
:80 {
    handle_path /api/* {
        reverse_proxy backend:4000
    }
    handle {
        reverse_proxy frontend:3000
    }
}
